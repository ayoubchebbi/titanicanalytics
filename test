Date startDate = Date.today().addDays(1);
Date endDate = Date.newInstance(Date.today().year(), 5, 31);

Id serviceTerritoryId = 'STTIX_TERRITORY_ID';
Id serviceResourceId  = 'STTIX_RESOURCE_ID';

List<Shift> shiftsToInsert = new List<Shift>();

for(Date d = startDate; d <= endDate; d = d.addDays(1)) {

    // 1 = Dimanche, 7 = Samedi
    Integer dayOfWeek = d.toStartOfWeek().daysBetween(d) + 1;

    // Skip dimanche
    if(dayOfWeek == 1) continue;

    // Samedi
    if(dayOfWeek == 7) {
        Datetime startMorning = Datetime.newInstance(d, Time.newInstance(8, 0, 0, 0));
        Datetime endMorning   = Datetime.newInstance(d, Time.newInstance(13, 0, 0, 0));

        shiftsToInsert.add(new Shift(
            StartTime = startMorning,
            EndTime = endMorning,
            ServiceTerritoryId = serviceTerritoryId,
            ServiceResourceId = serviceResourceId,
            Status = 'Draft'
        ));
    } 
    // Lundi → Vendredi
    else {
        // Matin
        Datetime startMorning = Datetime.newInstance(d, Time.newInstance(8, 0, 0, 0));
        Datetime endMorning   = Datetime.newInstance(d, Time.newInstance(12, 30, 0, 0));

        // Après-midi
        Datetime startAfternoon = Datetime.newInstance(d, Time.newInstance(14, 0, 0, 0));
        Datetime endAfternoon   = Datetime.newInstance(d, Time.newInstance(18, 0, 0, 0));

        shiftsToInsert.add(new Shift(
            StartTime = startMorning,
            EndTime = endMorning,
            ServiceTerritoryId = serviceTerritoryId,
            ServiceResourceId = serviceResourceId,
            Status = 'Draft'
        ));

        shiftsToInsert.add(new Shift(
            StartTime = startAfternoon,
            EndTime = endAfternoon,
            ServiceTerritoryId = serviceTerritoryId,
            ServiceResourceId = serviceResourceId,
            Status = 'Draft'
        ));
    }
}

insert shiftsToInsert;

System.debug('Shifts créés: ' + shiftsToInsert.size());
