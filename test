<?xml version="1.0" encoding="UTF-8"?>
<CustomLabels xmlns="http://soap.sforce.com/2006/04/metadata">
    <labels>
        <fullName>FSCO_CannotRescheduleMessage</fullName>
        <language>en_US</language>
        <protected>false</protected>
        <shortDescription>Cannot Reschedule Message</shortDescription>
        <value>We are unable to reschedule your appointment at this time. Please try again later.</value>
        <translations>
            <language>fr</language>
            <value>Nous ne sommes pas en mesure de replanifier votre rendez-vous pour le moment. Veuillez réessayer plus tard.</value>
        </translations>
        <translations>
            <language>it</language>
            <value>Non siamo in grado di riprogrammare il tuo appuntamento in questo momento. Riprova più tardi.</value>
        </translations>
        <translations>
            <language>de</language>
            <value>Wir können Ihren Termin derzeit nicht neu planen. Bitte versuchen Sie es später erneut.</value>
        </translations>
    </labels>
    <labels>
        <fullName>FSCO_ForbiddenPeriodMessage</fullName>
        <language>en_US</language>
        <protected>false</protected>
        <shortDescription>Forbidden Period Message</shortDescription>
        <value>Rescheduling is not available during this period. Please contact us for further assistance.</value>
        <translations>
            <language>fr</language>
            <value>La replanification n'est pas disponible durant cette période. Veuillez nous contacter pour obtenir de l'aide.</value>
        </translations>
        <translations>
            <language>it</language>
            <value>La riprogrammazione non è disponibile durante questo periodo. Contattaci per ulteriore assistenza.</value>
        </translations>
        <translations>
            <language>de</language>
            <value>Eine Umplanung ist in diesem Zeitraum nicht möglich. Bitte kontaktieren Sie uns für weitere Unterstützung.</value>
        </translations>
    </labels>
    <labels>
        <fullName>FSCO_ForbiddenPeriodAndCannotRescheduleMessage</fullName>
        <language>en_US</language>
        <protected>false</protected>
        <shortDescription>Forbidden Period And Cannot Reschedule Message</shortDescription>
        <value>Rescheduling is not available during this period and cannot be processed at this time. Please try again later or contact us for further assistance.</value>
        <translations>
            <language>fr</language>
            <value>La replanification n'est pas disponible durant cette période et ne peut pas être traitée pour le moment. Veuillez réessayer plus tard ou nous contacter pour obtenir de l'aide.</value>
        </translations>
        <translations>
            <language>it</language>
            <value>La riprogrammazione non è disponibile durante questo periodo e non può essere elaborata al momento. Riprova più tardi o contattaci per ulteriore assistenza.</value>
        </translations>
        <translations>
            <language>de</language>
            <value>Eine Umplanung ist in diesem Zeitraum nicht möglich und kann derzeit nicht bearbeitet werden. Bitte versuchen Sie es später erneut oder kontaktieren Sie uns für weitere Unterstützung.</value>
        </translations>
    </labels>
</CustomLabels>


private static String resolveMessage(String reason) {
    if (reason == REASON_CANNOT_RESCHEDULE) {
        return System.Label.FSCO_CannotRescheduleMessage;
    } else if (reason == REASON_FORBIDDEN_PERIOD) {
        return System.Label.FSCO_ForbiddenPeriodMessage;
    } else if (reason == REASON_BOTH) {
        return System.Label.FSCO_ForbiddenPeriodAndCannotRescheduleMessage;
    }
    return reason;
}
